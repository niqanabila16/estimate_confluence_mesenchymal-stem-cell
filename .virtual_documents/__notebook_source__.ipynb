# Cell 3: Custom Dataset Loader for COCO Format
import json
import cv2
import torch
from torch.utils.data import Dataset, DataLoader
from pycocotools import mask as mask_utils
import numpy as np
from pathlib import Path

class COCOMSCDataset(Dataset):
    """Custom Dataset for MSC Segmentation in COCO format"""
    
    def __init__(self, images_dir, annotations_path, image_size=1024):
        self.images_dir = Path(images_dir) 
        self.image_size = image_size
        
        # Load COCO annotations
        with open(annotations_path, 'r') as f:
            self.coco_data = json.load(f)
        
        # Build image and annotation mappings
        self.images = {img['id']: img for img in self.coco_data['images']}
        
        # Group annotations by image_id
        self.image_annotations = {}
        for ann in self.coco_data['annotations']:
            img_id = ann['image_id']
            if img_id not in self.image_annotations:
                self.image_annotations[img_id] = []
            self.image_annotations[img_id].append(ann)
        
        # Filter images that have annotations
        self.image_ids = [img_id for img_id in self.images.keys() 
                          if img_id in self.image_annotations]
        
        print(f"Loaded {len(self.image_ids)} images with annotations")
    
    def __len__(self):
        return len(self.image_ids)
    
    def __getitem__(self, idx):
            img_id = self.image_ids[idx]
            img_info = self.images[img_id]
            
            # 1. LOAD & ENHANCE IMAGE (CLAHE)
            img_path = self.images_dir / img_info['file_name']
            # Baca sebagai grayscale untuk diproses CLAHE
            image_gray = cv2.imread(str(img_path), cv2.IMREAD_GRAYSCALE)
            
            # Terapkan CLAHE agar batas sel MSCs lebih tajam
            clahe = cv2.createCLAHE(clipLimit=3.0, tileGridSize=(8,8))
            image_enhanced = clahe.apply(image_gray)
            
            # Konversi ke RGB (3-channel) karena SAM 2 memerlukannya
            image_rgb = cv2.cvtColor(image_enhanced, cv2.COLOR_GRAY2RGB)
            
            # 2. RESIZE IMAGE
            if image_rgb.shape[:2] != (self.image_size, self.image_size):
                image_rgb = cv2.resize(image_rgb, (self.image_size, self.image_size))
            
            # 3. MASK PROCESSING (LOGIKA MANUAL KAMU)
            mask = np.zeros((self.image_size, self.image_size), dtype=np.uint8)
            
            for ann in self.image_annotations[img_id]:
                if 'segmentation' in ann:
                    # Handle polygon format
                    if isinstance(ann['segmentation'], list):
                        for seg in ann['segmentation']:
                            poly = np.array(seg).reshape(-1, 2)
                            # Scaling polygon ke ukuran gambar yang baru
                            scale_x = self.image_size / img_info['width']
                            scale_y = self.image_size / img_info['height']
                            poly[:, 0] *= scale_x
                            poly[:, 1] *= scale_y
                            cv2.fillPoly(mask, [poly.astype(np.int32)], 1)
                    
                    # Handle RLE format
                    elif isinstance(ann['segmentation'], dict):
                        rle_mask = mask_utils.decode(ann['segmentation'])
                        if rle_mask.shape[:2] != (self.image_size, self.image_size):
                            rle_mask = cv2.resize(rle_mask, (self.image_size, self.image_size))
                        mask = np.maximum(mask, rle_mask)
    
            # 4. KONVERSI KE TENSOR & NORMALISASI (KRUSIAL)
            # Permute mengubah (H, W, C) menjadi (C, H, W)
            # Pembagian 255.0 menormalkan nilai piksel menjadi rentang [0, 1]
            image_tensor = torch.from_numpy(image_rgb).permute(2, 0, 1).float() / 255.0
            mask_tensor = torch.from_numpy(mask).float()
            
            return image_tensor, mask_tensor, img_info['file_name']

