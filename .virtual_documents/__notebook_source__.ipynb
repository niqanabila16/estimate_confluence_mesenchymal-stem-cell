# Visualize predictions
def visualize_predictions(model, dataset, num_samples=6, device='cuda'):
    """Visualize model predictions"""
    fig, axes = plt.subplots(num_samples, 3, figsize=(15, 5*num_samples))
    
    indices = np.random.choice(len(dataset), num_samples, replace=False)
    
    with torch.no_grad():
        for idx, sample_idx in enumerate(indices):
            image, mask, filename = dataset[sample_idx]
            
            # Prepare input
            image_input = image.unsqueeze(0).to(device)
            
            # Predict
            prediction = model(image_input)
            pred_mask = torch.sigmoid(prediction).squeeze().cpu().numpy()
            pred_binary = (pred_mask > 0.5).astype(np.uint8)
            
            # Convert image for display
            # img_display = image.permute(1, 2, 0).cpu().numpy().astype(np.uint8)
            img_display = (image.permute(1, 2, 0).cpu().numpy() * 255).astype(np.uint8)
            img_display = (img_display - img_display.min()) / (img_display.max() - img_display.min())
            gt_mask = mask.cpu().numpy()
            
            # Calculate IoU
            intersection = np.logical_and(pred_binary, gt_mask).sum()
            union = np.logical_or(pred_binary, gt_mask).sum()
            iou = intersection / union if union > 0 else 0
            
            # Plot
            axes[idx, 0].imshow(img_display)
            axes[idx, 0].set_title(f'Original Image\n{filename}', fontsize=10)
            axes[idx, 0].axis('off')
            
            axes[idx, 1].imshow(gt_mask, cmap='gray')
            axes[idx, 1].set_title('Ground Truth Mask', fontsize=10)
            axes[idx, 1].axis('off')
            
            axes[idx, 2].imshow(pred_binary, cmap='gray')
            axes[idx, 2].set_title(f'Predicted Mask\nIoU: {iou:.3f}', fontsize=10)
            axes[idx, 2].axis('off')
    
    plt.tight_layout()
    plt.savefig(os.path.join(CONFIG['save_dir'], 'predictions.png'), dpi=150, bbox_inches='tight')
    plt.show()

