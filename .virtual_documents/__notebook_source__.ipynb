# Cell 4: SAM 2 Model Initialization
import torch
import torch.nn as nn
from sam2.build_sam import build_sam2

class SAM2FineTuner(nn.Module):
    """Wrapper for SAM 2 with fine-tuning capabilities"""
    
    def __init__(self, checkpoint_path, model_cfg="sam2_hiera_l.yaml", device='cuda'):
        super().__init__()
        self.model = build_sam2(model_cfg, checkpoint_path, device=device)
        self.device = device
        
        # 1. Bekukan semua dulu
        for param in self.model.parameters():
            param.requires_grad = False
        
        # 2. Unfreeze Mask Decoder (Wajib untuk segmentasi)
        print("Unfreezing Mask Decoder...")
        for param in self.model.sam_mask_decoder.parameters():
            param.requires_grad = True
            
        # 3. Unfreeze Stage terakhir Image Encoder (Stage 4)
        # Ini agar model bisa "melihat" tekstur sel MSCs
        print("Unfreezing Stage 4 of Image Encoder (Hiera)...")
        if hasattr(self.model.image_encoder, 'blocks'):
            # Kita ambil 4 blok terakhir untuk varian Large
            for param in self.model.image_encoder.blocks[-4:].parameters():
                param.requires_grad = True
        
        # 4. Unfreeze Prompt Encoder (Opsional, tapi aman diaktifkan)
        for param in self.model.sam_prompt_encoder.parameters():
            param.requires_grad = True

        # Menghitung statistik parameter
        total_p = sum(p.numel() for p in self.model.parameters())
        trainable_p = sum(p.numel() for p in self.model.parameters() if p.requires_grad)
        
        print(f"\n📊 Model Statistics:")
        print(f"  Total parameters: {total_p:,}")
        print(f"  Trainable parameters: {trainable_p:,} ({trainable_p/total_p*100:.2f}%)")
        print(f"  Frozen parameters: {total_p - trainable_p:,}")
    
    def forward(self, images, target_size=1024):
        batch_size = images.shape[0]
        device = images.device
        
        # 1. Encode images
        backbone_out = self.model.forward_image(images)
        
        image_embeddings = backbone_out["vision_features"]
        high_res_features = backbone_out["backbone_fpn"][:2] 
        
        # 2. Prepare inputs (No-prompt setup)
        embed_dim = 256
        sparse_embeddings = torch.zeros((batch_size, 0, embed_dim), device=device)
        dense_embeddings = torch.zeros((batch_size, embed_dim, 64, 64), device=device)
        
        # 3. Predict masks
        decoder_out = self.model.sam_mask_decoder(
            image_embeddings=image_embeddings,
            image_pe=self.model.sam_prompt_encoder.get_dense_pe(),
            sparse_prompt_embeddings=sparse_embeddings,
            dense_prompt_embeddings=dense_embeddings,
            multimask_output=False,
            repeat_image=False,
            high_res_features=high_res_features,
        )
        
        # 4. Upsample ke target size
        low_res_masks = decoder_out[0]
        masks = torch.nn.functional.interpolate(
            low_res_masks,
            size=(target_size, target_size),
            mode='bilinear',
            align_corners=False
        )
        return masks

# Inisialisasi Model
device = 'cuda' if torch.cuda.is_available() else 'cpu'
print("Initializing SAM 2 Large model...")
model = SAM2FineTuner(MODEL_PATH, model_cfg="sam2_hiera_l.yaml", device=device)

if torch.cuda.device_count() > 1:
    model = nn.DataParallel(model)
    
model = model.to(device)
print("✅ Model ready for training!")


# Cell 5: Loss Functions (Focal + Dice)
import torch
import torch.nn as nn
import torch.nn.functional as F

class FocalLoss(nn.Module):
    """Focal Loss for handling class imbalance"""
    
    def __init__(self, alpha=0.8, gamma=2.0):
        super().__init__()
        self.alpha = alpha
        self.gamma = gamma
    
    def forward(self, inputs, targets):
        """
        Args:
            inputs: (B, 1, H, W) logits
            targets: (B, H, W) ground truth masks
        """
        inputs = inputs.squeeze(1)  # (B, H, W)
        
        # Flatten
        inputs = inputs.reshape(-1)
        targets = targets.reshape(-1)
        
        # Binary cross entropy with logits
        bce_loss = F.binary_cross_entropy_with_logits(inputs, targets, reduction='none')
        
        # Calculate focal term
        probs = torch.sigmoid(inputs)
        pt = torch.where(targets == 1, probs, 1 - probs)
        focal_term = (1 - pt) ** self.gamma
        
        # Apply alpha weighting
        alpha_t = torch.where(targets == 1, self.alpha, 1 - self.alpha)
        
        loss = alpha_t * focal_term * bce_loss
        return loss.mean()

class DiceLoss(nn.Module):
    """Dice Loss for segmentation"""
    
    def __init__(self, smooth=1.0):
        super().__init__()
        self.smooth = smooth
    
    def forward(self, inputs, targets):
        """
        Args:
            inputs: (B, 1, H, W) logits
            targets: (B, H, W) ground truth masks
        """
        inputs = torch.sigmoid(inputs)
        inputs = inputs.squeeze(1)  # (B, H, W)
        
        # Flatten
        inputs = inputs.reshape(-1)
        targets = targets.reshape(-1)
        
        intersection = (inputs * targets).sum()
        dice = (2. * intersection + self.smooth) / (inputs.sum() + targets.sum() + self.smooth)
        
        return 1 - dice

# Tambahkan ini di bagian paling bawah Cell 5
class CombinedLoss(nn.Module):
    """Gabungan Focal + Dice Loss (0.3/0.7) untuk hasil yang lebih filled & smooth"""
    def __init__(self, focal_weight=0.3, dice_weight=0.7):
        super().__init__()
        self.focal = FocalLoss(alpha=0.8, gamma=2.0)
        self.dice = DiceLoss()
        self.focal_weight = focal_weight
        self.dice_weight = dice_weight
        
    def forward(self, inputs, targets):
        f_loss = self.focal(inputs, targets)
        d_loss = self.dice(inputs, targets)
        return (self.focal_weight * f_loss) + (self.dice_weight * d_loss)

# Inisialisasi criterion di sini agar bisa dipanggil di training loop
criterion = CombinedLoss(focal_weight=0.3, dice_weight=0.7)

print("✅ Loss functions initialized: Focal Loss + Dice Loss")


