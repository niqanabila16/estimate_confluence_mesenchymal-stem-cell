import matplotlib.pyplot as plt
import torch
import numpy as np
import os

def evaluate_with_confluence(model, dataset, target_filename, device='cuda'):
    # 1. Cari index gambar berdasarkan filename
    img_idx = -1
    for i in range(len(dataset)):
        if dataset[i][2] == target_filename:
            img_idx = i
            break
    
    if img_idx == -1:
        print(f"❌ File {target_filename} tidak ditemukan!")
        return

    # 2. Ambil data & Inference
    image, mask, filename = dataset[img_idx]
    image_input = image.unsqueeze(0).to(device)
    
    model.eval()
    with torch.no_grad():
        prediction = model(image_input)
        # Menangani output SAM 2 yang mungkin berbentuk list/dict
        if isinstance(prediction, (list, tuple, dict)):
            pred_mask = torch.sigmoid(prediction[0]).squeeze().cpu().numpy()
        else:
            pred_mask = torch.sigmoid(prediction).squeeze().cpu().numpy()
            
    # 3. Thresholding & Conversion
    pred_binary = (pred_mask > 0.5).astype(np.uint8)
    gt_mask = mask.cpu().numpy().astype(np.uint8)
    total_pixels = gt_mask.size

    # 4. Hitung Metrik Segmentasi (IoU, Dice, dll)
    tp = np.logical_and(pred_binary == 1, gt_mask == 1).sum()
    fp = np.logical_and(pred_binary == 1, gt_mask == 0).sum()
    fn = np.logical_and(pred_binary == 0, gt_mask == 1).sum()
    
    iou = tp / (tp + fp + fn) if (tp + fp + fn) > 0 else 0
    dice = (2 * tp) / (2 * tp + fp + fn) if (2 * tp + fp + fn) > 0 else 0

    # 5. Hitung Metrik Confluence (Area Coverage)
    # Rumus: (Total piksel sel / Total piksel gambar) * 100%
    gt_confluence = (np.sum(gt_mask) / total_pixels) * 100
    pred_confluence = (np.sum(pred_binary) / total_pixels) * 100
    confluence_error = abs(gt_confluence - pred_confluence)

    # 6. Print Laporan Hasil
    print("=" * 65)
    print(f"DETAILED ANALYSIS FOR: {target_filename}")
    print("=" * 65)
    print(f"{'Metric':<25} | {'Value':<15}")
    print("-" * 65)
    print(f"{'Intersection over Union':<25} | {iou:.4f}")
    print(f"{'Dice Coefficient':<25} | {dice:.4f}")
    print("-" * 65)
    print(f"{'GT Confluence Area':<25} | {gt_confluence:.2f}%")
    print(f"{'Pred Confluence Area':<25} | {pred_confluence:.2f}%")
    print(f"{'Confluence Delta Error':<25} | {confluence_error:.2f}%")
    print("=" * 65)

    # 7. Visualisasi Perbandingan
    fig, axes = plt.subplots(1, 3, figsize=(20, 7))
    
    # Original
    # img_display = image.permute(1, 2, 0).cpu().numpy()
    # Ubah baris ini di Cell 8:
    img_display = (image.permute(1, 2, 0).cpu().numpy() * 255).astype(np.uint8)
    img_display = (img_display - img_display.min()) / (img_display.max() - img_display.min())
    axes[0].imshow(img_display)
    axes[0].set_title(f"Original: {target_filename}", fontsize=12)
    axes[0].axis('off')

    # Ground Truth
    axes[1].imshow(gt_mask, cmap='viridis')
    axes[1].set_title(f"Ground Truth\nConfluence: {gt_confluence:.2f}%", fontsize=12)
    axes[1].axis('off')

    # Prediction
    axes[2].imshow(pred_binary, cmap='magma')
    axes[2].set_title(f"SAM 2 Prediction\nConfluence: {pred_confluence:.2f}%", fontsize=12)
    axes[2].axis('off')

    plt.tight_layout()
    plt.show()
     
# Eksekusi untuk file spesifik
target_file = "218-6_part_25_tile_6.png"
evaluate_with_confluence(model, test_dataset, target_file, device=device)


# Cell 9: Calculate Comprehensive Evaluation Metrics
from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score
import torch
import numpy as np
from tqdm.auto import tqdm

def calculate_metrics(model, dataloader, device='cuda'):
    """Calculate comprehensive evaluation metrics"""
    model.eval()
    
    all_ious = []
    all_dice = []
    all_precision = []
    all_recall = []
    all_f1 = []
    
    with torch.no_grad():
        pbar = tqdm(dataloader, desc='Calculating metrics')
        for images, masks, _ in pbar:
            images = images.to(device)
            masks = masks.cpu().numpy()
            
            # Predict
            predictions = model(images)
            pred_masks = torch.sigmoid(predictions).squeeze(1).cpu().numpy()
            pred_binary = (pred_masks > 0.5).astype(np.uint8)
            
            # Calculate metrics for each sample in batch
            for pred, gt in zip(pred_binary, masks):
                pred_flat = pred.flatten()
                gt_flat = gt.flatten()
                
                # IoU
                intersection = np.logical_and(pred_flat, gt_flat).sum()
                union = np.logical_or(pred_flat, gt_flat).sum()
                iou = intersection / union if union > 0 else 0
                all_ious.append(iou)
                
                # Dice
                dice = (2 * intersection) / (pred_flat.sum() + gt_flat.sum()) if (pred_flat.sum() + gt_flat.sum()) > 0 else 0
                all_dice.append(dice)
                
                # Precision, Recall, F1
                precision = precision_score(gt_flat, pred_flat, zero_division=0)
                recall = recall_score(gt_flat, pred_flat, zero_division=0)
                f1 = f1_score(gt_flat, pred_flat, zero_division=0)
                
                all_precision.append(precision)
                all_recall.append(recall)
                all_f1.append(f1)
    
    metrics = {
        'IoU': np.mean(all_ious),
        'Dice': np.mean(all_dice),
        'Precision': np.mean(all_precision),
        'Recall': np.mean(all_recall),
        'F1-Score': np.mean(all_f1),
    }
    
    return metrics

# Calculate metrics on test set
print("Calculating evaluation metrics on test set...")
test_metrics = calculate_metrics(model, test_loader, device=device)

print("\n" + "=" * 60)
print("FINAL EVALUATION METRICS")
print("=" * 60)
for metric_name, value in test_metrics.items():
    print(f"{metric_name:15s}: {value:.4f}")
print("=" * 60)

# Save metrics
metrics_df = pd.DataFrame([test_metrics])
metrics_df.to_csv(os.path.join(CONFIG['save_dir'], 'test_metrics.csv'), index=False)
