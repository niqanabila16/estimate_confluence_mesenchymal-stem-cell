# Cell 6: Training Loop (Optimized for MSCs)
import torch
import torch.optim as optim
from tqdm.auto import tqdm
import os
import pandas as pd
from datetime import datetime

# Training configuration
CONFIG = {
    'epochs': 100, # Naikkan sedikit ke 15 jika unfreeze encoder
    'learning_rate': 1e-4,
    'weight_decay': 5e-4,
    'save_dir': '/kaggle/working/checkpoints',
    'log_interval': 10,
}

os.makedirs(CONFIG['save_dir'], exist_ok=True)

# Optimizer
# Update Optimizer agar mengambil parameter yang aktif secara benar
if isinstance(model, nn.DataParallel):
    trainable_params = [p for p in model.module.parameters() if p.requires_grad]
else:
    trainable_params = [p for p in model.parameters() if p.requires_grad]

optimizer = optim.AdamW(
    trainable_params, 
    lr=CONFIG['learning_rate'], 
    weight_decay=CONFIG['weight_decay']
)

print(f"✅ Optimizer siap dengan Weight Decay: {CONFIG['weight_decay']}")

# Learning rate scheduler
scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=CONFIG['epochs'], eta_min=1e-6)

# Training history
history = {
    'epoch': [],
    'train_loss': [],
    'test_loss': [],
    'learning_rate': []
}

def train_epoch(model, dataloader, criterion, optimizer, device):
    """Train for one epoch"""
    model.train()
    total_loss = 0.0
    num_batches = 0
    
    pbar = tqdm(dataloader, desc='Training', leave=False)
    for images, masks, _ in pbar:
        images = images.to(device)
        masks = masks.to(device)
        
        # Forward pass
        optimizer.zero_grad()
        predictions = model(images)
        
        # Calculate loss
        loss = criterion(predictions, masks)
        
        # Backward pass
        loss.backward()
        optimizer.step()
        
        total_loss += loss.item()
        num_batches += 1
        
        pbar.set_postfix({'loss': f'{loss.item():.4f}'})
    
    return total_loss / num_batches

def evaluate(model, dataloader, criterion, device):
    """Evaluate on test set"""
    model.eval()
    total_loss = 0.0
    num_batches = 0
    
    with torch.no_grad():
        pbar = tqdm(dataloader, desc='Evaluating', leave=False)
        for images, masks, _ in pbar:
            images = images.to(device)
            masks = masks.to(device)
            
            predictions = model(images)
            loss = criterion(predictions, masks)
            
            total_loss += loss.item()
            num_batches += 1
            
            pbar.set_postfix({'loss': f'{loss.item():.4f}'})
    
    return total_loss / num_batches

# Training loop
print("=" * 80)
print("STARTING TRAINING - SAM 2 LARGE FINE-TUNING")
print("=" * 80)
print(f"Epochs: {CONFIG['epochs']}")
print(f"Learning Rate: {CONFIG['learning_rate']}")
print(f"Batch Size: {train_loader.batch_size}")
print(f"Training Samples: {len(train_dataset)}")
print(f"Test Samples: {len(test_dataset)}")
print("=" * 80)

best_test_loss = float('inf')
start_time = datetime.now()

for epoch in range(CONFIG['epochs']):
    epoch_start = datetime.now()
    
    # Train
    train_loss = train_epoch(model, train_loader, criterion, optimizer, device)
    
    # Evaluate
    test_loss = evaluate(model, test_loader, criterion, device)
    
    # Update scheduler
    scheduler.step()
    current_lr = scheduler.get_last_lr()[0]
    
    # Save history
    history['epoch'].append(epoch + 1)
    history['train_loss'].append(train_loss)
    history['test_loss'].append(test_loss)
    history['learning_rate'].append(current_lr)
    
    # Print progress
    epoch_time = (datetime.now() - epoch_start).total_seconds()
    print(f"Epoch [{epoch+1}/{CONFIG['epochs']}] | "
          f"Train Loss: {train_loss:.4f} | "
          f"Test Loss: {test_loss:.4f} | "
          f"LR: {current_lr:.6f} | "
          f"Time: {epoch_time:.1f}s")
    
    # Save best model
    if test_loss < best_test_loss:
        best_test_loss = test_loss
        
        # Handle DataParallel when saving
        if isinstance(model, nn.DataParallel):
            model_state = model.module.state_dict()
        else:
            model_state = model.state_dict()
        
        checkpoint = {
            'epoch': epoch + 1,
            'model_state_dict': model_state,
            'optimizer_state_dict': optimizer.state_dict(),
            'test_loss': test_loss,
            'train_loss': train_loss,
        }
        
        checkpoint_path = os.path.join(CONFIG['save_dir'], 'best_model.pth')
        torch.save(checkpoint, checkpoint_path)
        print(f"  💾 Saved best model (test_loss: {test_loss:.4f})")
    
    # Save checkpoint every 10 epochs
    if (epoch + 1) % 10 == 0:
        if isinstance(model, nn.DataParallel):
            model_state = model.module.state_dict()
        else:
            model_state = model.state_dict()
        
        checkpoint = {
            'epoch': epoch + 1,
            'model_state_dict': model_state,
            'optimizer_state_dict': optimizer.state_dict(),
            'test_loss': test_loss,
            'train_loss': train_loss,
        }
        
        checkpoint_path = os.path.join(CONFIG['save_dir'], f'checkpoint_epoch_{epoch+1}.pth')
        torch.save(checkpoint, checkpoint_path)

total_time = (datetime.now() - start_time).total_seconds()
print("\n" + "=" * 80)
print("TRAINING COMPLETE!")
print("=" * 80)
print(f"Total time: {total_time/60:.1f} minutes")
print(f"Best test loss: {best_test_loss:.4f}")
print(f"Model saved to: {CONFIG['save_dir']}/best_model.pth")

# Save training history
# Save training history
history_df = pd.DataFrame(history)
history_path = os.path.join(CONFIG['save_dir'], 'training_history.csv')
history_df.to_csv(history_path, index=False)
print(f"📊 Training history saved to: {history_path}")


import matplotlib.pyplot as plt
import torch
import numpy as np
import cv2
    
def compare_thresholds(model, dataset, target_filename, thresholds=[0.5, 0.6, 0.7], device='cuda'):
    # 1. Cari gambar spesifik
    img_idx = next((i for i, x in enumerate(dataset) if x[2] == target_filename), -1)
    if img_idx == -1: return print("❌ File tidak ditemukan")

    # 2. Inference
    image, mask, filename = dataset[img_idx]
    model.eval()
    with torch.no_grad():
        pred = model(image.unsqueeze(0).to(device))
        if isinstance(pred, (list, tuple, dict)): pred = pred[0]
        pred_mask = torch.sigmoid(pred).squeeze().cpu().numpy()

    # 3. Visualisasi
    fig, axes = plt.subplots(1, len(thresholds) + 1, figsize=(20, 5))
    
    # Tampilkan Ground Truth (Referensi)
    axes[0].imshow(mask.cpu().numpy(), cmap='gray')
    axes[0].set_title("GROUND TRUTH\n(Standard)", fontsize=10)
    axes[0].axis('off')

    for i, thresh in enumerate(thresholds):
        # Terapkan threshold
        binary = (pred_mask > thresh).astype(np.uint8)
        
        # Hitung IoU sederhana
        inter = np.logical_and(binary, mask.cpu().numpy()).sum()
        union = np.logical_or(binary, mask.cpu().numpy()).sum()
        iou = inter / union if union > 0 else 0
        
        axes[i+1].imshow(binary, cmap='magma')
        axes[i+1].set_title(f"Threshold: {thresh}\nIoU: {iou:.4f}", fontsize=10)
        axes[i+1].axis('off')

    plt.suptitle(f"Analisis Sensitivitas Threshold - {target_filename}", fontsize=14, y=1.05)
    plt.tight_layout()
    plt.show()

# Eksekusi untuk melihat perbedaannya
compare_thresholds(model, test_dataset, "218-6_part_25_tile_6.png")


